{
  "info": {
    "name": "PraiOn API — v2",
    "description": "Collection completa de rotas da API PraiOn (inclui Cardápio Admin, Mesas, Pedidos, Upload e Socket.io events).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token",      "value": "",                           "type": "string" },
    { "key": "categoriaId","value": "1",                          "type": "string" },
    { "key": "itemId",     "value": "1",                          "type": "string" },
    { "key": "mesaId",     "value": "1",                          "type": "string" },
    { "key": "pedidoId",   "value": "1",                          "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Usuario Teste\",\n  \"email\": \"usuario@praion.com\",\n  \"senha\": \"Senha@123\",\n  \"telefone\": \"11999999999\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var d = pm.response.json();",
                "if (d && d.data && d.data.token) pm.collectionVariables.set('token', d.data.token);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@praion.com\",\n  \"senha\": \"Admin@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth","me"] }
          }
        }
      ]
    },
    {
      "name": "Cardápio (Público)",
      "item": [
        {
          "name": "Listar Cardápio",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/cardapio", "host": ["{{baseUrl}}"], "path": ["cardapio"] }
          }
        }
      ]
    },
    {
      "name": "Categorias (Admin)",
      "item": [
        {
          "name": "Listar Categorias",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/categorias", "host": ["{{baseUrl}}"], "path": ["categorias"] }
          }
        },
        {
          "name": "Criar Categoria",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Sobremesas\",\n  \"ativo\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/categorias", "host": ["{{baseUrl}}"], "path": ["categorias"] }
          }
        },
        {
          "name": "Editar Categoria",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Doces e Sobremesas\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/categorias/{{categoriaId}}", "host": ["{{baseUrl}}"], "path": ["categorias","{{categoriaId}}"] }
          }
        },
        {
          "name": "Remover Categoria",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/categorias/{{categoriaId}}", "host": ["{{baseUrl}}"], "path": ["categorias","{{categoriaId}}"] }
          }
        }
      ]
    },
    {
      "name": "Itens do Cardápio (Admin)",
      "item": [
        {
          "name": "Criar Item em Categoria",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Pudim de Leite\",\n  \"descricao\": \"Receita caseira com calda de caramelo\",\n  \"preco\": 15.00,\n  \"disponivel\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/categorias/{{categoriaId}}/itens", "host": ["{{baseUrl}}"], "path": ["categorias","{{categoriaId}}","itens"] }
          }
        },
        {
          "name": "Editar Item",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Pudim de Leite Condensado\",\n  \"preco\": 17.50\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/itens/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["itens","{{itemId}}"] }
          }
        },
        {
          "name": "Remover Item",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/itens/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["itens","{{itemId}}"] }
          }
        },
        {
          "name": "Alterar Disponibilidade",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"disponivel\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/itens/{{itemId}}/disponibilidade", "host": ["{{baseUrl}}"], "path": ["itens","{{itemId}}","disponibilidade"] }
          }
        }
      ]
    },
    {
      "name": "Upload de Mídia",
      "item": [
        {
          "name": "Upload de Imagem",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": { "raw": "{{baseUrl}}/upload", "host": ["{{baseUrl}}"], "path": ["upload"] }
          }
        }
      ]
    },
    {
      "name": "Mesas",
      "item": [
        {
          "name": "Listar Mesas",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/mesas", "host": ["{{baseUrl}}"], "path": ["mesas"] }
          }
        },
        {
          "name": "Criar Mesa",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numero\": 10,\n  \"capacidade\": 4\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/mesas", "host": ["{{baseUrl}}"], "path": ["mesas"] }
          }
        },
        {
          "name": "Remover Mesa",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/mesas/{{mesaId}}", "host": ["{{baseUrl}}"], "path": ["mesas","{{mesaId}}"] }
          }
        },
        {
          "name": "Chamar Garçom",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/mesas/{{mesaId}}/chamar-garcom", "host": ["{{baseUrl}}"], "path": ["mesas","{{mesaId}}","chamar-garcom"] }
          }
        },
        {
          "name": "Pedidos da Mesa",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/mesas/{{mesaId}}/pedidos", "host": ["{{baseUrl}}"], "path": ["mesas","{{mesaId}}","pedidos"] }
          }
        },
        {
          "name": "Fechar Conta",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/mesas/{{mesaId}}/fechar-conta", "host": ["{{baseUrl}}"], "path": ["mesas","{{mesaId}}","fechar-conta"] }
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Listar Todos (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Criar Pedido",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mesaId\": 1,\n  \"total\": 106.83,\n  \"itens\": [\n    { \"id\": 1, \"nome\": \"Camarão Frito\", \"quantidade\": 1, \"preco\": 85.00 },\n    { \"id\": 2, \"nome\": \"Cerveja\",        \"quantidade\": 1, \"preco\": 21.83 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Atualizar Status",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"preparando\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/pedidos/{{pedidoId}}/status", "host": ["{{baseUrl}}"], "path": ["pedidos","{{pedidoId}}","status"] }
          }
        }
      ]
    },
    {
      "name": "Sistema",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
